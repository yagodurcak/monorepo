{
  "button": {
    "bg": {
      "primary":         { "$value": "{color.action.default}",   "$type": "color" },
      "primary-hover":   { "$value": "{color.action.hover}",     "$type": "color" },
      "primary-active":  { "$value": "{color.action.active}",    "$type": "color" },
      "secondary":       { "$value": "{color.secondary.default}","$type": "color" },
      "secondary-hover": { "$value": "{color.secondary.hover}",  "$type": "color" },
      "secondary-active":{ "$value": "{color.secondary.active}", "$type": "color" },
      "outline-hover":   { "$value": "{color.action.subtle}",    "$type": "color" }
    },
    "text": {
      "primary":        { "$value": "{color.text.on-action}",  "$type": "color" },
      "secondary":      { "$value": "{color.text.on-action}",  "$type": "color" },
      "outline":        { "$value": "{color.action.default}",  "$type": "color" },
      "outline-hover":  { "$value": "{color.action.hover}",    "$type": "color" },
      "outline-active": { "$value": "{color.action.active}",   "$type": "color" }
    },
    "border": {
      "outline":        { "$value": "{color.action.default}", "$type": "color" },
      "outline-hover":  { "$value": "{color.action.hover}",   "$type": "color" },
      "radius":         { "$value": "{border-radius.md}",     "$type": "dimension" }
    },
    "padding": {
      "sm": {
        "x": { "$value": "{spacing.3}", "$type": "dimension" },
        "y": { "$value": "{spacing.1}", "$type": "dimension" }
      },
      "md": {
        "x": { "$value": "{spacing.4}", "$type": "dimension" },
        "y": { "$value": "{spacing.2}", "$type": "dimension" }
      },
      "lg": {
        "x": { "$value": "{spacing.6}", "$type": "dimension" },
        "y": { "$value": "{spacing.3}", "$type": "dimension" }
      }
    }
  }
}
