{
  "font": {
    "family": {
      "$type": "fontFamily",
      "base": { "$value": "'Inter', sans-serif" }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "md": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.25rem" }
    },
    "weight": {
      "$type": "number",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "tight":   { "$value": 1.25 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.75 }
    }
  }
}
