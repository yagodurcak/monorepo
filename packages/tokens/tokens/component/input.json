{
  "input": {
    "bg": {
      "default":  { "$value": "{color.background.default}", "$type": "color" },
      "disabled": { "$value": "{color.background.subtle}",  "$type": "color" }
    },
    "text": {
      "default":     { "$value": "{color.text.default}",    "$type": "color" },
      "placeholder": { "$value": "{color.text.muted}",      "$type": "color" },
      "label":       { "$value": "{color.text.default}",    "$type": "color" },
      "error":       { "$value": "{color.feedback.error}",  "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.border.default}", "$type": "color" },
      "focus":   { "$value": "{color.border.focus}",   "$type": "color" },
      "error":   { "$value": "{color.border.error}",   "$type": "color" },
      "radius":  { "$value": "{border-radius.md}",     "$type": "dimension" }
    },
    "padding": {
      "sm": {
        "x": { "$value": "{spacing.3}", "$type": "dimension" },
        "y": { "$value": "{spacing.1}", "$type": "dimension" }
      },
      "md": {
        "x": { "$value": "{spacing.4}", "$type": "dimension" },
        "y": { "$value": "{spacing.2}", "$type": "dimension" }
      },
      "lg": {
        "x": { "$value": "{spacing.4}", "$type": "dimension" },
        "y": { "$value": "{spacing.3}", "$type": "dimension" }
      }
    }
  }
}
