{
  "color": {
    "background": {
      "default": { "$value": "{color.neutral.0}" },
      "subtle":   { "$value": "{color.neutral.100}" }
    },
    "text": {
      "default":   { "$value": "{color.neutral.900}" },
      "muted":     { "$value": "{color.neutral.500}" },
      "on-action": { "$value": "{color.neutral.0}" }
    },
    "action": {
      "default": { "$value": "{color.primary.500}" },
      "hover":   { "$value": "{color.primary.700}" },
      "active":  { "$value": "{color.primary.900}" },
      "subtle":  { "$value": "{color.primary.100}" }
    },
    "secondary": {
      "default": { "$value": "{color.secondary.500}" },
      "hover":   { "$value": "{color.secondary.700}" },
      "active":  { "$value": "{color.secondary.900}" }
    },
    "border": {
      "default": { "$value": "{color.neutral.300}" },
      "focus":   { "$value": "{color.primary.500}" },
      "error":   { "$value": "{color.error.500}" }
    },
    "feedback": {
      "error":   { "$value": "{color.error.500}" },
      "success": { "$value": "{color.success.500}" },
      "warning": { "$value": "{color.warning.500}" }
    }
  }
}
